<?xml version="1.0" encoding="UTF-8"?>
<archimate:model xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:archimate="http://www.archimatetool.com/archimate" name="ForwardService — Ford Challenge FIAP 2026" id="id-a3d684c8e72c" version="4.10.0">
  <folder name="Motivation" id="id-e088e9962221" type="motivation">
    <element xsi:type="archimate:Stakeholder" name="Ford Brasil (Diretoria)" id="id-002a2f3f98d9">
      <documentation>Diretoria executiva — quer VIN Share crescente e ROI mensurável</documentation>
    </element>
    <element xsi:type="archimate:Stakeholder" name="Concessionária (Dealer)" id="id-ae4cb76591a6">
      <documentation>145 dealers ativos — precisa de leads priorizados e IHC</documentation>
    </element>
    <element xsi:type="archimate:Stakeholder" name="Cliente Ford" id="id-47f535aa1e54">
      <documentation>Dono de veículo Ford — quer lembrete proativo e experiência simplificada</documentation>
    </element>
    <element xsi:type="archimate:Stakeholder" name="Gestor Regional Ford" id="id-ddef721ad6c0">
      <documentation>Compara performance de dealers por UF</documentation>
    </element>
    <element xsi:type="archimate:Stakeholder" name="Equipe ForwardService" id="id-678c9f3e6cd4">
      <documentation>4 desenvolvedores FIAP — entregam plataforma</documentation>
    </element>
    <element xsi:type="archimate:Driver" name="Churn pós-garantia" id="id-2ef8058420d9">
      <documentation>Retenção despenca de 82% para 20-40% ao término da garantia (Cox Automotive 2025)</documentation>
    </element>
    <element xsi:type="archimate:Driver" name="VIN Share baixo" id="id-f32b17959bb5">
      <documentation>Apenas ~3,5-5% da frota Ford usa a rede oficial — 95% vai para independentes</documentation>
    </element>
    <element xsi:type="archimate:Driver" name="3,4M Recalls pendentes" id="id-4af525ef6458">
      <documentation>Taxa de atendimento de recalls no Brasil: ~40%. Novo CTB bloqueia licenciamento</documentation>
    </element>
    <element xsi:type="archimate:Driver" name="Frota descontinuada" id="id-fc04b0380fe2">
      <documentation>80% da frota são Ka/Fiesta/EcoSport — sem app, sem lembrete oficial</documentation>
    </element>
    <element xsi:type="archimate:Goal" name="Aumentar VIN Share" id="id-5586086122f0">
      <documentation>Meta: VIN Share ≥ 8% em 24 meses (base: ~3,5-5%)</documentation>
    </element>
    <element xsi:type="archimate:Goal" name="Reduzir churn pós-venda" id="id-392d86d067b4">
      <documentation>Aumentar taxa de retorno pós-1ª revisão de 71% para ≥ 80%</documentation>
    </element>
    <element xsi:type="archimate:Goal" name="ROI mensurável" id="id-5506aceff8bb">
      <documentation>Cada ação rastreada do disparo ao resultado financeiro em R$</documentation>
    </element>
    <element xsi:type="archimate:Goal" name="Escalar cobertura" id="id-9b8a9dbdce88">
      <documentation>Alcançar clientes de modelos descontinuados via Fluxo Simplificado</documentation>
    </element>
    <element xsi:type="archimate:Requirement" name="REQ-01: Latência API p95 &lt; 300ms" id="id-261474cc3d07">
      <documentation>Performance: endpoint p95 abaixo de 300ms</documentation>
    </element>
    <element xsi:type="archimate:Requirement" name="REQ-02: Disponibilidade ≥ 99%" id="id-dd816ad4d10a">
      <documentation>SLA: no máximo 7h15 de downtime por ano</documentation>
    </element>
    <element xsi:type="archimate:Requirement" name="REQ-03: AUC classificador ≥ 0,82" id="id-be3bda42f067">
      <documentation>ML: XGBoost com target engenheirado — dias_sem_revisão &gt; 365</documentation>
    </element>
    <element xsi:type="archimate:Requirement" name="REQ-04: Falsos positivos churn &lt; 10%" id="id-5314fe54221b">
      <documentation>Qualidade do modelo de segmentação K-means</documentation>
    </element>
    <element xsi:type="archimate:Requirement" name="REQ-05: LGPD — dados pseudonimizados" id="id-4ec674696e5b">
      <documentation>VIN_Hash SHA1 + salt. Sem PII reversível no pipeline ML</documentation>
    </element>
    <element xsi:type="archimate:Requirement" name="REQ-06: Onboarding atendente &lt; 15 min" id="id-44defbbf9477">
      <documentation>UX: atendente operacional sem treinamento longo</documentation>
    </element>
    <element xsi:type="archimate:Requirement" name="REQ-07: Entrega WhatsApp &lt; 30s" id="id-1bd39f136c57">
      <documentation>n8n + Meta Business API: confirmação em 30 segundos</documentation>
    </element>
    <element xsi:type="archimate:Principle" name="SOA — Portão Único" id="id-80cfb8cba108">
      <documentation>Tudo passa pelo forward-api-java. Mobile/Web não falam direto com banco ou ML</documentation>
    </element>
    <element xsi:type="archimate:Principle" name="Flywheel de Dados" id="id-9447adfd197b">
      <documentation>Cada ciclo de ação gera dado que melhora o modelo. Precisão cresce com uso</documentation>
    </element>
    <element xsi:type="archimate:Principle" name="Proatividade sobre reatividade" id="id-0c8257e19923">
      <documentation>A plataforma age antes do cliente sair — não espera ele sumir</documentation>
    </element>
  </folder>
  <folder name="Strategy" id="id-d45bed9eaf09" type="strategy"/>
  <folder name="Business" id="id-bba316d5a691" type="business">
    <element xsi:type="archimate:BusinessActor" name="Atendente" id="id-3219f11fd2a9">
      <documentation>Func. da concessionária — usa app mobile Modo Ford</documentation>
    </element>
    <element xsi:type="archimate:BusinessActor" name="Gerente de Serviço" id="id-183f1f573f5d">
      <documentation>Gerencia leads e NPS do dealer</documentation>
    </element>
    <element xsi:type="archimate:BusinessActor" name="Diretor Regional" id="id-0e6fc6c34064">
      <documentation>Usa dashboard web para visão macro</documentation>
    </element>
    <element xsi:type="archimate:BusinessActor" name="Cliente Ativo" id="id-bc6e5d026ed8">
      <documentation>Dono de Ford que ainda usa a rede</documentation>
    </element>
    <element xsi:type="archimate:BusinessActor" name="Cliente Churned" id="id-c8a4024aa98c">
      <documentation>Dono de Ford que parou de usar a rede</documentation>
    </element>
    <element xsi:type="archimate:BusinessRole" name="Gestor de Retenção" id="id-5ba27699623d">
      <documentation>Responsável por campanhas de reativação</documentation>
    </element>
    <element xsi:type="archimate:BusinessRole" name="Analista ML" id="id-057485811225">
      <documentation>Opera e retreina os modelos de segmentação/classificação</documentation>
    </element>
    <element xsi:type="archimate:BusinessProcess" name="Processo AS-IS: Pós-Venda Ford" id="id-9e0d28dce5c2">
      <documentation>Processo atual: sem proatividade, sem segmentação, sem ROI rastreável</documentation>
    </element>
    <element xsi:type="archimate:BusinessProcess" name="Segmentar Clientes" id="id-5b59f714bf92">
      <documentation>K-means cego sobre 175k VINs — 4 perfis: Fiel/Econômico/Esquecido/Abandono</documentation>
    </element>
    <element xsi:type="archimate:BusinessProcess" name="Priorizar Leads" id="id-2e3aca7b87d5">
      <documentation>Pulse Leads: ordenar por risco × LSV — lista diária para o atendente</documentation>
    </element>
    <element xsi:type="archimate:BusinessProcess" name="Disparar Ação" id="id-3f7fc796e4f0">
      <documentation>CommEngine: WhatsApp personalizado via n8n no momento crítico</documentation>
    </element>
    <element xsi:type="archimate:BusinessProcess" name="Medir ROI" id="id-c8ad041b24d4">
      <documentation>Closed-Loop ROI: rastrear ação → resposta → agendamento → receita em R$</documentation>
    </element>
    <element xsi:type="archimate:BusinessProcess" name="Recall como Porta" id="id-f624d10195cc">
      <documentation>Recall Gateway: transformar recall pendente em oportunidade de reconexão</documentation>
    </element>
    <element xsi:type="archimate:BusinessProcess" name="Agendamento Digital" id="id-afdb16ca743d">
      <documentation>Cliente agenda pelo app ou WhatsApp em 1 toque</documentation>
    </element>
    <element xsi:type="archimate:BusinessService" name="Serviço de Scoring" id="id-1b67df9e8f6e">
      <documentation>API que devolve segmento + score de churn + ação sugerida por VIN</documentation>
    </element>
    <element xsi:type="archimate:BusinessService" name="Serviço de Leads" id="id-e8fa5204a489">
      <documentation>API que devolve lista priorizada para o dealer do dia</documentation>
    </element>
    <element xsi:type="archimate:BusinessService" name="Serviço de Notificação" id="id-ebe559400121">
      <documentation>Dispara WhatsApp/push/email via n8n</documentation>
    </element>
    <element xsi:type="archimate:BusinessService" name="Serviço de Agendamento" id="id-39838971a795">
      <documentation>Registra e confirma revisão no banco</documentation>
    </element>
    <element xsi:type="archimate:BusinessObject" name="VIN (Vehicle ID)" id="id-2519ff96c141">
      <documentation>Número de chassi pseudonimizado — unidade de análise central do sistema</documentation>
    </element>
    <element xsi:type="archimate:BusinessObject" name="Score de Churn" id="id-25495ff66d8e">
      <documentation>Probabilidade 0-100 de abandono de um VIN. Atualizado 1×/dia.</documentation>
    </element>
    <element xsi:type="archimate:BusinessObject" name="Perfil de Segmento" id="id-abb8c89a150b">
      <documentation>Fiel | Econômico | Esquecido | Abandono — saída do K-means</documentation>
    </element>
    <element xsi:type="archimate:BusinessObject" name="Ação Recomendada" id="id-c86bfbe2d9ba">
      <documentation>O que fazer com o cliente: whatsapp | ligação | email | deixar quieto</documentation>
    </element>
    <element xsi:type="archimate:BusinessObject" name="IHC — Saúde do Dealer" id="id-773e2f8d0cd6">
      <documentation>Score 0-100 da concessionária (VIN Share 25% + Conversão 20% + NPS 15% + outros)</documentation>
    </element>
  </folder>
  <folder name="Application" id="id-95bfb2c8a67e" type="application">
    <element xsi:type="archimate:ApplicationComponent" name="forward-api-java" id="id-65669a9b6b00">
      <documentation>Backend core — Java 17 + Spring Boot 3.2. Portão único: REST + SOAP. JWT/RBAC. Flyway. SpringDoc OpenAPI.</documentation>
    </element>
    <element xsi:type="archimate:ApplicationComponent" name="forward-ml" id="id-18d5d9406e60">
      <documentation>Serviço de ML — Python. K-means (segmentador) + XGBoost (classificador) + Kaplan-Meier (survival). Roda 1×/dia via cron.</documentation>
    </element>
    <element xsi:type="archimate:ApplicationComponent" name="forward-mobile" id="id-258468a8f0d1">
      <documentation>App React Native/Expo. Dual-mode: Modo Ford (atendente) + Modo Cliente. 3 telas Sprint 1.</documentation>
    </element>
    <element xsi:type="archimate:ApplicationComponent" name="forward-web" id="id-f51042c8b8bf">
      <documentation>Dashboard SvelteKit. Cockpit Ford corporativo. Read-only. Chart.js/visx. Consome só forward-api-java.</documentation>
    </element>
    <element xsi:type="archimate:ApplicationComponent" name="n8n (Action Engine)" id="id-bd32156a4142">
      <documentation>Orquestrador low-code self-hosted. Inbound: webhook WhatsApp → Java. Outbound: Java → WhatsApp template.</documentation>
    </element>
    <element xsi:type="archimate:ApplicationComponent" name="Supabase / PostgreSQL" id="id-2636edc598be">
      <documentation>Banco gerenciado. Fonte da verdade. Só forward-api-java e segmentador batch escrevem.</documentation>
    </element>
    <element xsi:type="archimate:ApplicationInterface" name="REST API (OpenAPI)" id="id-c64e94aaac70">
      <documentation>Endpoints públicos: /clients, /leads, /scores, /classify, /analytics</documentation>
    </element>
    <element xsi:type="archimate:ApplicationInterface" name="SOAP / WSDL" id="id-4ad556adf966">
      <documentation>Operação GetVehicle — requisito SOA (Prof. Salatiel). WSDL exposto.</documentation>
    </element>
    <element xsi:type="archimate:ApplicationInterface" name="WebSocket Push" id="id-1cc473143205">
      <documentation>Notificações em tempo real para o app mobile (push notifications)</documentation>
    </element>
    <element xsi:type="archimate:ApplicationInterface" name="WhatsApp Business API" id="id-30e4d93f15a5">
      <documentation>Integração Meta — templates aprovados, 97% abertura, ROI 300:1</documentation>
    </element>
    <element xsi:type="archimate:ApplicationService" name="Scoring Service" id="id-a3f498a64a4e">
      <documentation>Calcula segmento + score + ação sugerida via ML</documentation>
    </element>
    <element xsi:type="archimate:ApplicationService" name="Lead Prioritization" id="id-331bd2bcd91e">
      <documentation>Gera lista diária Pulse Leads por dealer</documentation>
    </element>
    <element xsi:type="archimate:ApplicationService" name="Notification Service" id="id-6174edc53b5a">
      <documentation>Orquestra envio via n8n (WhatsApp/email/push)</documentation>
    </element>
    <element xsi:type="archimate:ApplicationService" name="Analytics Service" id="id-4f1ec733ba4e">
      <documentation>Agrega KPIs para dashboard web (IHC, VIN Share, Curva da Morte)</documentation>
    </element>
    <element xsi:type="archimate:ApplicationService" name="Auth/RBAC Service" id="id-10f94a4f29a2">
      <documentation>JWT HS256 + roles: attendant/manager/dealer_owner/ford_regional/ford_admin</documentation>
    </element>
    <element xsi:type="archimate:ApplicationService" name="Audit Trail Service" id="id-7dc0e5c839cc">
      <documentation>Registra acesso e ações em audit_log (LGPD)</documentation>
    </element>
    <element xsi:type="archimate:DataObject" name="vin_features.csv" id="id-18e72e938c85">
      <documentation>175k VINs × 20+ features comportamentais — input pro ML</documentation>
    </element>
    <element xsi:type="archimate:DataObject" name="client_segments" id="id-1cecd3e219b8">
      <documentation>Tabela: etiqueta + segmento por VIN. Atualizada 1×/dia pelo segmentador</documentation>
    </element>
    <element xsi:type="archimate:DataObject" name="client_scores" id="id-5a4b7a4d622d">
      <documentation>Tabela: score 0-100 + probabilidades por VIN + versão do modelo</documentation>
    </element>
    <element xsi:type="archimate:DataObject" name="recommended_actions" id="id-5d22fc3be983">
      <documentation>Tabela: ação sugerida, motivo, template, status (pending/dispatched/done)</documentation>
    </element>
    <element xsi:type="archimate:DataObject" name="audit_log" id="id-1085a834fd10">
      <documentation>Trilha completa: quem acessou o quê, quando, antes/depois (LGPD)</documentation>
    </element>
  </folder>
  <folder name="Technology" id="id-88aad8b507a5" type="technology">
    <element xsi:type="archimate:Node" name="Azure VM (B-series)" id="id-45bc48940019">
      <documentation>Standard_B1s ou B2s — hospeda Java + n8n + ML Python via Docker</documentation>
    </element>
    <element xsi:type="archimate:Node" name="Supabase Cloud / Neon" id="id-d1c8ef721e7d">
      <documentation>Banco PostgreSQL 16 gerenciado — free/pro tier</documentation>
    </element>
    <element xsi:type="archimate:Node" name="Vercel / Netlify" id="id-6cd425c00da0">
      <documentation>Hospedagem estática do forward-web (free tier)</documentation>
    </element>
    <element xsi:type="archimate:SystemSoftware" name="Docker Engine" id="id-fa451b4e1a71">
      <documentation>Containeriza forward-api-java + n8n + ML script na Azure VM</documentation>
    </element>
    <element xsi:type="archimate:SystemSoftware" name="PostgreSQL 16" id="id-256bcd179de7">
      <documentation>Banco relacional — fonte da verdade de todo o sistema</documentation>
    </element>
    <element xsi:type="archimate:SystemSoftware" name="JVM (Java 17)" id="id-359f3863726d">
      <documentation>Runtime do Spring Boot 3.2 — HikariCP, Flyway, SpringDoc</documentation>
    </element>
    <element xsi:type="archimate:SystemSoftware" name="Python 3.11" id="id-75488d224c65">
      <documentation>Runtime ML — scikit-learn, pandas, lifelines, matplotlib</documentation>
    </element>
    <element xsi:type="archimate:SystemSoftware" name="n8n (Docker)" id="id-6857019ac60b">
      <documentation>Orquestrador de workflows low-code — self-hosted na VM</documentation>
    </element>
    <element xsi:type="archimate:TechnologyInterface" name="HTTPS / TLS 1.2+" id="id-d3f4ba3354a4">
      <documentation>Toda comunicação externa criptografada. HTTPS forçado.</documentation>
    </element>
    <element xsi:type="archimate:TechnologyInterface" name="WhatsApp Business API (Meta)" id="id-fc83a92789ee">
      <documentation>Entrega de mensagens para clientes — 97% abertura no BR</documentation>
    </element>
    <element xsi:type="archimate:TechnologyInterface" name="Expo Push API" id="id-c682b6e1400e">
      <documentation>Notificações push para app mobile via Expo</documentation>
    </element>
    <element xsi:type="archimate:TechnologyInterface" name="GitHub Actions CI" id="id-a6081c313e65">
      <documentation>Pipeline de build + teste automático a cada PR</documentation>
    </element>
    <element xsi:type="archimate:CommunicationNetwork" name="Azure VNet" id="id-dde7ce2748ad">
      <documentation>Rede privada que isola VM + banco + n8n internamente</documentation>
    </element>
    <element xsi:type="archimate:CommunicationNetwork" name="Internet / CDN" id="id-102c31c3eff2">
      <documentation>Tráfego externo — mobile, web, WhatsApp webhook</documentation>
    </element>
    <element xsi:type="archimate:Artifact" name="forward-api-java.jar" id="id-3421bd1376f4">
      <documentation>Build artefato Spring Boot — deployado via Docker na VM</documentation>
    </element>
    <element xsi:type="archimate:Artifact" name="forward-mobile.apk/.ipa" id="id-30de6797437d">
      <documentation>Bundle Expo — publicado via EAS Build (30 builds/mês free)</documentation>
    </element>
    <element xsi:type="archimate:Artifact" name="forward-web (static)" id="id-f62c7246331f">
      <documentation>Build SvelteKit — deployado no Vercel/Netlify</documentation>
    </element>
    <element xsi:type="archimate:Artifact" name="ML models (pickle/joblib)" id="id-252712886c3c">
      <documentation>Modelos treinados persistidos no filesystem da VM</documentation>
    </element>
    <element xsi:type="archimate:Artifact" name="Flyway migrations" id="id-0abc1bb8b1aa">
      <documentation>Versionamento do schema PostgreSQL — entrega obrigatória SOA</documentation>
    </element>
  </folder>
  <folder name="Implementation" id="id-e357cb62367b" type="implementation_migration">
    <element xsi:type="archimate:WorkPackage" name="Sprint 1 — Entrega 24/05/2026" id="id-01e99c489804">
      <documentation>ML + Java + Mobile + Web + n8n + Infra + QA</documentation>
    </element>
    <element xsi:type="archimate:Deliverable" name="PITCH.pptx" id="id-ccde7ebecac0">
      <documentation>QA-1: Apresentação 15 slides</documentation>
    </element>
    <element xsi:type="archimate:Deliverable" name="CANVAS.pdf" id="id-a8850d01d776">
      <documentation>QA-2: Business Model Canvas</documentation>
    </element>
    <element xsi:type="archimate:Deliverable" name="QUADRO_DE_VALOR.pdf" id="id-27ba9d6eba91">
      <documentation>QA-3: Quadro de Valor com métricas negócio + qualidade</documentation>
    </element>
    <element xsi:type="archimate:Deliverable" name="ForwardService.archimate" id="id-a2864e9f4db7">
      <documentation>QA-4: Arquitetura TOGAF/Archi</documentation>
    </element>
    <element xsi:type="archimate:Deliverable" name="VIDEO_PITCH.mp4" id="id-a2de2fe7efc6">
      <documentation>QA-5: Vídeo ≤3min com 4 integrantes</documentation>
    </element>
  </folder>
  <folder name="Other" id="id-75b7e2d3034b" type="other">
    <element xsi:type="archimate:Assessment" name="Grafana Dashboard" id="id-f9a4056b3c6d">
      <documentation>Monitor de latência, throughput, erros da API Java + n8n</documentation>
    </element>
    <element xsi:type="archimate:Assessment" name="Alert: API p95 &gt; 300ms" id="id-a95469d5dfc8">
      <documentation>Alerta quando latência ultrapassa SLA — dispara para equipe</documentation>
    </element>
    <element xsi:type="archimate:Assessment" name="Alert: Disponibilidade &lt;99%" id="id-470a7eaa83a0">
      <documentation>Alerta de downtime — SLA: no máximo 7h15/ano</documentation>
    </element>
    <element xsi:type="archimate:Assessment" name="audit_log viewer" id="id-53f7af633a14">
      <documentation>Interface interna para revisar trilha de auditoria LGPD</documentation>
    </element>
    <element xsi:type="archimate:Assessment" name="ML Model Monitor" id="id-08fcd1f15c76">
      <documentation>Monitora AUC, drift de dados, qualidade do segmentador mensalmente</documentation>
    </element>
    <element xsi:type="archimate:Assessment" name="Cron segmentador 02h" id="id-a4fc48d7d826">
      <documentation>Job Linux que roda run_segmenter.py 1×/dia e escreve em client_segments</documentation>
    </element>
  </folder>
